fn main() : void {
    let a : int = str_vec_new();
    let b : int = str_vec_new();

    str_vec_push(a, "a0");
    str_vec_push(a, "a1");

    str_vec_push(b, "b0");
    str_vec_push(b, "b1");
    str_vec_push(b, "b2");

    print_int(str_vec_len(a));
    print_str(str_vec_get(a, 0));
    print_str(str_vec_get(a, 1));

    print_int(str_vec_len(b));
    print_str(str_vec_get(b, 0));
    print_str(str_vec_get(b, 1));
    print_str(str_vec_get(b, 2));

    return;
}
