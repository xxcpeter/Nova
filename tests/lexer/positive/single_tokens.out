PLUS("+") at 1:1
MINUS("-") at 2:1
STAR("*") at 3:1
SLASH("/") at 4:1
PERCENT("%") at 5:1
ASSIGN("=") at 6:1
EQ_EQ("==") at 7:1
BANG_EQ("!=") at 8:1
LT("<") at 9:1
LE("<=") at 10:1
GT(">") at 11:1
GE(">=") at 12:1
AND_AND("&&") at 13:1
OR_OR("||") at 14:1
BANG("!") at 15:1
LPAREN("(") at 16:1
RPAREN(")") at 17:1
LBRACE("{") at 18:1
RBRACE("}") at 19:1
COMMA(",") at 20:1
SEMIC(";") at 21:1
COLON(":") at 22:1
EndOfFile("") at 23:1
