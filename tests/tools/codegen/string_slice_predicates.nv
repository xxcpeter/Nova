fn main() : void {
    let s : str = "hello world";
    print_str(str_slice(s, 0, 5));

    if (str_starts_with(s, "hello")) {
        print_str("starts");
    }

    if (str_contains(s, "world")) {
        print_str("contains");
    }

    if (str_eq(str_slice(s, 6, 11), "world")) {
        print_str("equal");
    }

    return;
}
