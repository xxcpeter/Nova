{
  "scopeName": "source.nova",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#struct-declarations"
    },
    {
      "include": "#function-declarations"
    },
    {
      "include": "#function-calls"
    },
    {
      "include": "#field-access"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.nova",
          "match": "//.*$"
        },
        {
          "name": "comment.block.nova",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nova",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.nova",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nova",
          "match": "\\b(if|else|while|return)\\b"
        },
        {
          "name": "keyword.declaration.nova",
          "match": "\\b(fn|let|struct)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.nova",
          "match": "\\b(int|bool|str|void)\\b"
        },
        {
          "name": "storage.type.vector.nova",
          "match": "\\bvec\\b"
        },
        {
          "name": "entity.name.type.struct.nova",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },

    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.nova",
          "match": "\\b(true|false)\\b"
        }
      ]
    },

    "builtins": {
      "patterns": [
        {
          "name": "support.function.runtime.nova",
          "match": "\\b(print_int|print_str|str_eq|str_concat|str_len|str_get|str_slice|str_starts_with|str_contains|int_to_str|read_file|write_file|buf_new|buf_push_str|buf_push_int|buf_to_str|arg_count|arg_get)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.vector.nova",
          "match": "\\b(vec_new|vec_len|vec_push|vec_get|vec_set)\\b(?=\\s*\\()"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.nova",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "struct-declarations": {
      "patterns": [
        {
          "name": "entity.name.type.struct.declaration.nova",
          "match": "(?<=\\bstruct\\s+)[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },

    "function-declarations": {
      "patterns": [
        {
          "name": "entity.name.function.declaration.nova",
          "match": "(?<=\\bfn\\s+)[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },

    "function-calls": {
      "patterns": [
        {
          "name": "entity.name.function.call.nova",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },

    "field-access": {
      "patterns": [
        {
          "name": "variable.other.member.nova",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.nova",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.nova",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.nova",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.nova",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.access.nova",
          "match": "\\."
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.nova",
          "match": "[,;:]"
        },
        {
          "name": "punctuation.bracket.round.nova",
          "match": "[()]"
        },
        {
          "name": "punctuation.bracket.curly.nova",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.generic.nova",
          "match": "[<>]"
        }
      ]
    }
  }
}