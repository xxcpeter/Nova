{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Nova",
  "scopeName": "source.nova",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#imports"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#enumMembers"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.nova",
          "match": "//.*$"
        },
        {
          "name": "comment.block.nova",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nova",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.nova",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.nova",
          "match": "\\b(import)\\s+(\"[^\"]*\")\\s*(;)",
          "captures": {
            "1": {
              "name": "keyword.control.import.nova"
            },
            "2": {
              "name": "string.quoted.double.import-path.nova"
            },
            "3": {
              "name": "punctuation.terminator.statement.nova"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nova",
          "match": "\\b(if|else|while|return)\\b"
        },
        {
          "name": "keyword.declaration.nova",
          "match": "\\b(fn|let|struct|enum|import)\\b"
        },
        {
          "name": "constant.language.boolean.nova",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.nova",
          "match": "\\b(int|bool|str|void)\\b"
        },
        {
          "name": "storage.type.vector.nova",
          "match": "\\bvec\\b"
        },
        {
          "name": "entity.name.type.nova",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.runtime.nova",
          "match": "\\b(print_int|print_str|str_eq|str_concat|str_len|str_get|str_slice|str_starts_with|str_contains|int_to_str|read_file|write_file|buf_new|buf_push_str|buf_push_int|buf_to_str|arg_count|arg_get|nova_runtime_error)\\b"
        },
        {
          "name": "support.function.vector.nova",
          "match": "\\b(vec_new|vec_push|vec_get|vec_set|vec_len)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.nova",
          "match": "\\bfn\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.function.nova"
            }
          }
        },
        {
          "name": "meta.struct.nova",
          "match": "\\bstruct\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.type.struct.nova"
            }
          }
        },
        {
          "name": "meta.enum.nova",
          "match": "\\benum\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.type.enum.nova"
            }
          }
        },
        {
          "name": "meta.variable.declaration.nova",
          "match": "\\blet\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "variable.other.local.nova"
            }
          }
        }
      ]
    },
    "enumMembers": {
      "patterns": [
        {
          "name": "meta.enum-member-access.nova",
          "match": "\\b([A-Z][A-Za-z0-9_]*)(\\.)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.type.enum.nova"
            },
            "2": {
              "name": "punctuation.accessor.dot.nova"
            },
            "3": {
              "name": "constant.other.enum.member.nova"
            }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.nova",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.nova",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.nova",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.nova",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.nova",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "punctuation.accessor.dot.nova",
          "match": "\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.nova",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.nova",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.nova",
          "match": ":"
        },
        {
          "name": "punctuation.definition.brace.nova",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.paren.nova",
          "match": "[()]"
        },
        {
          "name": "punctuation.definition.angle.nova",
          "match": "[<>]"
        }
      ]
    }
  }
}